NODE_ENV=development
PORT=5000

# MongoDB connection string (Atlas or local). Replace with your own URI.
MONGODB_URI=mongodb://127.0.0.1:27017/user-management

# JWT — use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Public URL of the web app (used in dev logs for reset / verify links when email is not wired)
APP_PUBLIC_URL=http://localhost:5173

# Email verification: when true, signup does not return JWT until /auth/verify-email completes
REQUIRE_EMAIL_VERIFICATION=false

# When true, most authenticated routes return 403 until email is verified
BLOCK_UNVERIFIED_API=false

# Initial admin (npm run seed); change password after first login in production
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMeAdmin!1
SEED_ADMIN_NAME=System Administrator

# Optional: restrict CORS in production (comma-separated origins)
# CORS_ORIGIN=http://localhost:5173,https://app.example.com
